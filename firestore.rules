rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isSystemAdmin() { return request.auth != null && request.auth.uid == 'VSnotQzmWMfmqbeB144IJ2xhciq2'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() { 
      return isSystemAdmin() || (isSignedIn() && userExists() && getUserData().role in ['ADMIN', 'SYSTEM_ADMIN', 'ALL_IN_ONE']); 
    }
    
    function isRole(role) {
      return isSignedIn() && userExists() && getUserData().role == role;
    }
    
    function isSupervisor() {
      return isSystemAdmin() || isRole('SUPERVISOR') || isAdmin();
    }

    // --- Entity Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
          && data.uid is string && data.uid.size() <= 128
          && data.email is string && data.email.size() <= 256;
    }

    // --- Rules ---

    // 1. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSupervisor());
      allow list: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSupervisor());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isSystemAdmin());
      // Admins handle user creation/deletion/role updates
      allow create, delete: if isAdmin() || isSystemAdmin();
    }

    // Fleet
    match /fleet/{fleetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isSystemAdmin() || isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow write: if isSignedIn();
    }

    // Requests (Abstract)
    match /{collection}/{requestId} {
      allow get: if collection in ['service_requests', 'camera_requests', 'vehicle_requests', 'studio_requests', 'item_requests', 'device_requests', 'guest_requests']
                && isSignedIn() && (isSystemAdmin() || isAdmin() || isSupervisor() || isRole('SECURITY') || resource.data.directorId == request.auth.uid || resource.data.assignedTechnicianId == request.auth.uid);
      allow list: if collection in ['service_requests', 'camera_requests', 'vehicle_requests', 'studio_requests', 'item_requests', 'device_requests', 'guest_requests']
                 && isSignedIn() && (isSystemAdmin() || isAdmin() || isSupervisor() || isRole('SECURITY') || resource.data.directorId == request.auth.uid || resource.data.assignedTechnicianId == request.auth.uid);
      
      allow create: if collection in ['service_requests', 'camera_requests', 'vehicle_requests', 'studio_requests', 'item_requests', 'device_requests', 'guest_requests']
                   && isSignedIn() && (isRole('DEPT_DIRECTOR') || isAdmin() || isSystemAdmin())
                   && incoming().status == 'NEW';
      
      allow update: if collection in ['service_requests', 'camera_requests', 'vehicle_requests', 'studio_requests', 'item_requests', 'device_requests', 'guest_requests']
                   && isSignedIn() && (
                      isSystemAdmin() || isAdmin() || isSupervisor() || isRole('SECURITY') || (resource.data.assignedTechnicianId == request.auth.uid) || (resource.data.directorId == request.auth.uid)
                   );
      allow delete: if collection in ['service_requests', 'camera_requests', 'vehicle_requests', 'studio_requests', 'item_requests', 'device_requests', 'guest_requests']
                   && isSignedIn() && (isAdmin() || isSystemAdmin());
    }
    
    // Department Updates
    match /department_updates/{updateId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || isSystemAdmin() || isSupervisor() || isRole('DEPT_DIRECTOR'));
      allow update: if isSignedIn() && (isAdmin() || isSystemAdmin() || isRole('DEPT_DIRECTOR'));
      allow delete: if isSignedIn();
    }
    
    // SMS Logs
    match /sim_sms_logs/{logId} {
      allow create: if isSignedIn() && (isAdmin() || isSystemAdmin());
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.recipientId == request.auth.uid);
    }
  }
}
