rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to check if user is writing their own document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /service_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /camera_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /vehicle_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /item_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /device_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /guest_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /fleet/{fleetId} {
      allow read, write: if isSignedIn();
    }

    match /sim_sms_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }
    
    // Catch-all rules for nested collections
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
