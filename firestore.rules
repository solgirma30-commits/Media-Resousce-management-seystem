rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'; 
    }
    function isRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))                
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // --- Entity Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
          && data.uid is string && data.uid.size() <= 128
          && data.email is string && data.email.size() <= 256
          && data.role in ['ADMIN', 'DEPT_DIRECTOR', 'TECHNICIAN'];
    }

    // --- Rules ---

    // 1. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && request.auth.uid == userId 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber'])
                     && isValidUser(incoming());
      // Admins handle user creation/deletion/role updates
      allow create, delete: if isAdmin();
    }

    // Fleet
    match /fleet/{fleetId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Requests (Abstract)
    match /{collection}/{requestId} {
      allow get: if collection in ['service_requests', 'camera_requests', 'vehicle_requests']
                && isSignedIn() && (isAdmin() || resource.data.directorId == request.auth.uid || resource.data.assignedTechnicianId == request.auth.uid);
      allow list: if collection in ['service_requests', 'camera_requests', 'vehicle_requests']
                 && isSignedIn() && (isAdmin() || resource.data.directorId == request.auth.uid || resource.data.assignedTechnicianId == request.auth.uid);
      
      allow create: if collection in ['service_requests', 'camera_requests', 'vehicle_requests']
                   && isSignedIn() && isRole('DEPT_DIRECTOR')
                   && incoming().directorId == request.auth.uid
                   && incoming().status == 'NEW';
      
      allow update: if collection in ['service_requests', 'camera_requests', 'vehicle_requests']
                   && isSignedIn() && (
                      isAdmin() || (resource.data.assignedTechnicianId == request.auth.uid) || (resource.data.directorId == request.auth.uid)
                   );
    }
    
    // SMS Logs
    match /sim_sms_logs/{logId} {
      allow create: if false; // System only
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.recipientId == request.auth.uid);
    }
  }
}
